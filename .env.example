# SAP Analytical Portal Failure Alert System
# Copy this file to .env and replace the placeholders with real values.

# Base configuration
BASE_URL=https://your-sap-portal-host:40000

# SAP / HANA credentials
DB_INSTANCE=your-hana-instance
COMPANY_DB=your-company-db
SAP_USERNAME=your-sap-username
SAP_PASSWORD=your-sap-password

# Email configuration
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SENDER_EMAIL=sender@example.com
SENDER_PASSWORD=your-email-password

# Notification recipients
EMAIL_TO=recipient1@example.com
EMAIL_CC=recipient2@example.com,recipient3@example.com

# MobiAlert HANA database connection
HANA_ADDRESS=your-hana-address
HANA_PORT=30015
HANA_USER=your-hana-user
HANA_PASSWORD=your-hana-password
DB_NAME=MOBIALERT
